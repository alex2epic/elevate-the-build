{
  "rewrites": [
    { "source": "/funnel", "destination": "/funnel.html" },
    { "source": "/quiz", "destination": "/funnel.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
